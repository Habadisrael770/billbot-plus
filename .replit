modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-mail:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
BILLBOT_PUBLIC_BASE_URL = "https://billibot.net"
BILLBOT_GMAIL_SCAN_ENDPOINT = "https://billibot.net/api/public/gmail-scan"
BILLBOT_INVOICES_ENDPOINT = "https://billibot.net/api/public/invoices"
BILLBOT_SUMMARY_ENDPOINT = "https://billibot.net/api/public/summary"
TWILIO_WHATSAPP_NUMBER = "whatsapp:+14155238886"
GOOGLE_REDIRECT_URI = "https://billibot.net/api/gmail-auth/callback"
HERMES_BRIDGE_URL = "http://srv1412520.hstgr.cloud/hermes"

[userenv.production]

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 19180
externalPort = 3000

[[ports]]
localPort = 21928
externalPort = 3001

[[ports]]
localPort = 22657
externalPort = 3002

[[ports]]
localPort = 26108
externalPort = 3003
